---
import { fetchHome } from "@api/home";
import NewLayout from "@layouts/NewLayout.astro";
import Navigation from '@components/Navigation.astro';
import HeroImage from '@components/HeroImage.astro';
import { tiptapToHtml } from "@utils/tiptap";

const home = await fetchHome();
const parsedDescription = tiptapToHtml(home.description);
const plainDescription = home.short_description ?? '';

// Get hero image URL - use hero field if set, otherwise fallback
const heroImageUrl = home.hero ?? "https://static.ivokun.com/large_Connection_6f16270cb4.JPG";
---

<NewLayout 
  title="HOME - IVOKUN BLOG" 
  description={plainDescription}
  ogImage={heroImageUrl}
>
  <Navigation />
  <HeroImage 
    title="IVOKUN BLOG"
    subtitle="Raw. Bold. Unfiltered."
    description={plainDescription}
    imageUrl={heroImageUrl}
    imageAlt="Two silhouetted figures standing against a brightly lit marble-patterned wall, creating dramatic contrast between dark figures and illuminated background"
  />
</NewLayout>
