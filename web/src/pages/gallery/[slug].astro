---
import NewLayout from '@layouts/NewLayout.astro';
import Navigation from '@components/Navigation.astro';
import { fetchGalleries, fetchGalleryBySlug, type Gallery, getGalleryImageUrl } from '@api/gallery';

export async function getStaticPaths() {
  const response = await fetchGalleries({ limit: 100 });
  const galleries = response.data;

  if (!galleries || galleries.length === 0) {
    return [];
  }

  return galleries.map((gallery) => ({
    params: { slug: gallery.slug },
    props: { gallery },
  }));
}

const { slug } = Astro.params;
const { gallery } = Astro.props as { gallery: Gallery };

// Get category name
const categoryName = gallery.category?.name?.toLowerCase() ?? 'uncategorized';

// Get all image URLs for the lightbox
const imageUrls = gallery.images.map((img, index) => ({
  index,
  thumbnail: getGalleryImageUrl(img, 'thumbnail') || '',
  small: getGalleryImageUrl(img, 'small') || '',
  large: getGalleryImageUrl(img, 'large') || '',
  original: getGalleryImageUrl(img, 'original') || '',
  alt: img.alt || `${gallery.title} - Image ${index + 1}`,
}));
---

<NewLayout 
  title={`${gallery.title} - IVOKUN BLOG`}
  description={gallery.description || `View ${gallery.title} in IVOKUN's Gallery`}
  ogImage={imageUrls[0]?.large}
>
  <Navigation />
  
  <main id="main-content" class="gallery-viewer">
    <div class="gallery-container">
      {/* Header */}
      <div class="gallery-header">
        <a href="/gallery" class="back-link">
          ← BACK TO GALLERY
        </a>
        <div class="gallery-counter">
          {gallery.images.length} {gallery.images.length === 1 ? 'image' : 'images'}
        </div>
      </div>

      {/* Gallery Info */}
      <div class="gallery-info-section">
        <div class="gallery-meta">
          {gallery.category && (
            <span class="gallery-category" data-category={categoryName}>
              {gallery.category.name.toUpperCase()}
            </span>
          )}
        </div>
        <h1 class="gallery-title">{gallery.title}</h1>
        {gallery.description && (
          <p class="gallery-description">{gallery.description}</p>
        )}
      </div>

      {/* Image Grid */}
      <div class="gallery-image-grid" id="imageGrid">
        {imageUrls.map((image, index) => (
          <button 
            class="gallery-image-item" 
            data-index={index}
            aria-label={`View image ${index + 1} of ${imageUrls.length}`}
          >
            <img 
              src={image.small} 
              alt={image.alt}
              loading={index < 6 ? "eager" : "lazy"}
            />
            <div class="image-overlay">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                <line x1="11" y1="8" x2="11" y2="14"></line>
                <line x1="8" y1="11" x2="14" y2="11"></line>
              </svg>
            </div>
          </button>
        ))}
      </div>

      {/* Navigation to Other Galleries */}
      <div class="gallery-navigation-footer">
        <a href="/gallery" class="view-all-link">
          VIEW ALL GALLERIES →
        </a>
      </div>
    </div>
  </main>

  {/* Lightbox Modal */}
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <div class="lightbox-backdrop"></div>
    <div class="lightbox-content">
      {/* Close Button */}
      <button class="lightbox-close" id="lightboxClose" aria-label="Close lightbox">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      {/* Main Image */}
      <div class="lightbox-main">
        <button class="lightbox-nav lightbox-prev" id="lightboxPrev" aria-label="Previous image">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        
        <div class="lightbox-image-container">
          <img id="lightboxImage" src="" alt="" />
          <div class="lightbox-loading" id="lightboxLoading">
            <div class="loading-spinner"></div>
          </div>
        </div>
        
        <button class="lightbox-nav lightbox-next" id="lightboxNext" aria-label="Next image">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>

      {/* Thumbnail Strip */}
      <div class="lightbox-thumbnails" id="lightboxThumbnails">
        {imageUrls.map((image, index) => (
          <button 
            class="lightbox-thumb" 
            data-index={index}
            aria-label={`Go to image ${index + 1}`}
          >
            <img src={image.thumbnail} alt={image.alt} loading="lazy" />
          </button>
        ))}
      </div>

      {/* Image Counter */}
      <div class="lightbox-counter">
        <span id="currentIndex">1</span> / <span id="totalCount">{imageUrls.length}</span>
      </div>
    </div>
  </div>
</NewLayout>

<style>
  /* Gallery Viewer Layout */
  .gallery-viewer {
    min-height: 100vh;
    padding: 2rem 0;
  }

  .gallery-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .gallery-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 4px solid var(--color-black);
  }

  .back-link {
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-black);
    border: 3px solid var(--color-black);
    padding: 0.75rem 1.25rem;
    background: var(--color-white);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .back-link:hover {
    background: var(--color-black);
    color: var(--color-white);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--color-blue);
  }

  .gallery-counter {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-gray);
    text-transform: uppercase;
  }

  /* Gallery Info Section */
  .gallery-info-section {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .gallery-meta {
    margin-bottom: 1rem;
  }

  .gallery-category {
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border: 2px solid var(--color-black);
    color: var(--color-black);
  }

  .gallery-category[data-category="tech"],
  .gallery-category[data-category="technology"] {
    border-color: var(--color-blue);
    color: var(--color-blue);
  }

  .gallery-category[data-category="photography"] {
    border-color: var(--color-black);
    color: var(--color-black);
  }

  .gallery-category[data-category="travel"] {
    border-color: #e74c3c;
    color: #e74c3c;
  }

  .gallery-category[data-category="food"] {
    border-color: #f39c12;
    color: #f39c12;
  }

  .gallery-category[data-category="science"] {
    border-color: #27ae60;
    color: #27ae60;
  }

  .gallery-category[data-category="business"] {
    border-color: #3498db;
    color: #3498db;
  }

  .gallery-category[data-category="music"] {
    border-color: #9b59b6;
    color: #9b59b6;
  }

  .gallery-category[data-category="lifestyle"] {
    border-color: #e91e63;
    color: #e91e63;
  }

  .gallery-category[data-category="programming"] {
    border-color: #00bcd4;
    color: #00bcd4;
  }

  .gallery-category[data-category="design"] {
    border-color: #ff5722;
    color: #ff5722;
  }

  .gallery-category[data-category="uncategorized"] {
    border-color: var(--color-gray);
    color: var(--color-gray);
  }

  .gallery-title {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    text-transform: none;
    line-height: 1.2;
  }

  .gallery-description {
    font-size: 1.1rem;
    color: var(--color-gray);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Image Grid */
  .gallery-image-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .gallery-image-item {
    position: relative;
    aspect-ratio: 4/3;
    border: 4px solid var(--color-black);
    overflow: hidden;
    background: var(--color-white);
    cursor: zoom-in;
    padding: 0;
    transition: all 0.3s ease;
  }

  .gallery-image-item:hover {
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 var(--color-blue);
  }

  .gallery-image-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .gallery-image-item:hover img {
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  .gallery-image-item:hover .image-overlay {
    background: rgba(0, 0, 0, 0.3);
  }

  .image-overlay svg {
    color: var(--color-white);
    opacity: 0;
    transform: scale(0.8);
    transition: all 0.3s ease;
    width: 48px;
    height: 48px;
  }

  .gallery-image-item:hover .image-overlay svg {
    opacity: 1;
    transform: scale(1);
  }

  /* Footer Navigation */
  .gallery-navigation-footer {
    text-align: center;
    padding-top: 2rem;
    border-top: 4px solid var(--color-black);
  }

  .view-all-link {
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-black);
    border: 3px solid var(--color-black);
    padding: 1rem 2rem;
    background: var(--color-white);
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-block;
  }

  .view-all-link:hover {
    background: var(--color-black);
    color: var(--color-white);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--color-blue);
  }

  /* Lightbox Styles */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
  }

  .lightbox-content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .lightbox-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 10;
    background: var(--color-white);
    border: 3px solid var(--color-black);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .lightbox-close:hover {
    background: var(--color-black);
    color: var(--color-white);
    transform: scale(1.1);
  }

  .lightbox-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 5rem;
    gap: 1rem;
  }

  .lightbox-nav {
    background: var(--color-white);
    border: 3px solid var(--color-black);
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .lightbox-nav:hover {
    background: var(--color-black);
    color: var(--color-white);
    transform: scale(1.1);
  }

  .lightbox-nav:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .lightbox-nav:disabled:hover {
    background: var(--color-white);
    color: var(--color-black);
    transform: none;
  }

  .lightbox-image-container {
    position: relative;
    max-width: calc(100% - 140px);
    max-height: calc(100vh - 200px);
  }

  .lightbox-image-container img {
    max-width: 100%;
    max-height: calc(100vh - 200px);
    object-fit: contain;
    display: block;
  }

  .lightbox-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
  }

  .lightbox-loading.hidden {
    display: none;
  }

  .loading-spinner {
    width: 40px;
    height: 40px;
    border: 4px solid var(--color-white);
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .lightbox-thumbnails {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    overflow-x: auto;
    background: rgba(0, 0, 0, 0.8);
    justify-content: center;
  }

  .lightbox-thumb {
    width: 70px;
    height: 70px;
    border: 3px solid transparent;
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    background: var(--color-black);
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .lightbox-thumb:hover {
    border-color: var(--color-white);
  }

  .lightbox-thumb.active {
    border-color: var(--color-blue);
  }

  .lightbox-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lightbox-counter {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    background: var(--color-black);
    color: var(--color-white);
    padding: 0.75rem 1.25rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.9rem;
  }

  /* Mobile Styles */
  @media (max-width: 768px) {
    .gallery-viewer {
      padding: 1rem 0;
    }

    .gallery-container {
      padding: 0 1rem;
    }

    .gallery-header {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
      margin-bottom: 1.5rem;
    }

    .back-link {
      font-size: 0.8rem;
      padding: 0.6rem 1rem;
    }

    .gallery-info-section {
      margin-bottom: 1.5rem;
    }

    .gallery-title {
      font-size: 1.75rem;
    }

    .gallery-description {
      font-size: 1rem;
    }

    .gallery-image-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 0.75rem;
    }

    .gallery-image-item {
      border-width: 3px;
    }

    /* Lightbox Mobile */
    .lightbox-main {
      padding: 3.5rem 0.5rem;
    }

    .lightbox-nav {
      width: 40px;
      height: 40px;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
    }

    .lightbox-prev {
      left: 0.5rem;
    }

    .lightbox-next {
      right: 0.5rem;
    }

    .lightbox-image-container {
      max-width: 100%;
      max-height: calc(100vh - 180px);
    }

    .lightbox-image-container img {
      max-height: calc(100vh - 180px);
    }

    .lightbox-thumbnails {
      padding: 0.75rem;
      gap: 0.5rem;
    }

    .lightbox-thumb {
      width: 50px;
      height: 50px;
    }

    .lightbox-close {
      top: 0.75rem;
      right: 0.75rem;
      width: 40px;
      height: 40px;
    }

    .lightbox-counter {
      top: 0.75rem;
      left: 0.75rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.8rem;
    }
  }
</style>

<script define:vars={{ images: imageUrls }}>
  // Lightbox functionality
  // @ts-nocheck
  const lightbox = document.getElementById('lightbox');
  const lightboxImage = document.getElementById('lightboxImage');
  const lightboxClose = document.getElementById('lightboxClose');
  const lightboxPrev = document.getElementById('lightboxPrev');
  const lightboxNext = document.getElementById('lightboxNext');
  const lightboxThumbnails = document.getElementById('lightboxThumbnails');
  const currentIndexEl = document.getElementById('currentIndex');
  const totalCountEl = document.getElementById('totalCount');
  const lightboxLoading = document.getElementById('lightboxLoading');
  const imageGrid = document.getElementById('imageGrid');
  
  let currentIndex = 0;
  
  function openLightbox(index) {
    currentIndex = index;
    updateLightboxImage();
    lightbox.classList.add('active');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    updateThumbnails();
  }
  
  function closeLightbox() {
    lightbox.classList.remove('active');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }
  
  function updateLightboxImage() {
    const image = images[currentIndex];
    lightboxLoading.classList.remove('hidden');
    
    // Use large size for lightbox
    lightboxImage.src = image.large;
    lightboxImage.alt = image.alt;
    
    lightboxImage.onload = () => {
      lightboxLoading.classList.add('hidden');
    };
    
    currentIndexEl.textContent = currentIndex + 1;
    updateThumbnails();
    updateNavButtons();
  }
  
  function updateThumbnails() {
    const thumbs = lightboxThumbnails.querySelectorAll('.lightbox-thumb');
    thumbs.forEach((thumb, index) => {
      thumb.classList.toggle('active', index === currentIndex);
      // Scroll active thumbnail into view
      if (index === currentIndex) {
        thumb.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
    });
  }
  
  function updateNavButtons() {
    lightboxPrev.disabled = currentIndex === 0;
    lightboxNext.disabled = currentIndex === images.length - 1;
  }
  
  function goToPrev() {
    if (currentIndex > 0) {
      currentIndex--;
      updateLightboxImage();
    }
  }
  
  function goToNext() {
    if (currentIndex < images.length - 1) {
      currentIndex++;
      updateLightboxImage();
    }
  }
  
  // Event Listeners
  if (imageGrid) {
    imageGrid.querySelectorAll('.gallery-image-item').forEach((item, index) => {
      item.addEventListener('click', () => openLightbox(index));
    });
  }
  
  if (lightboxClose) {
    lightboxClose.addEventListener('click', closeLightbox);
  }
  
  if (lightboxPrev) {
    lightboxPrev.addEventListener('click', goToPrev);
  }
  
  if (lightboxNext) {
    lightboxNext.addEventListener('click', goToNext);
  }
  
  // Thumbnail clicks
  if (lightboxThumbnails) {
    lightboxThumbnails.querySelectorAll('.lightbox-thumb').forEach((thumb, index) => {
      thumb.addEventListener('click', () => {
        currentIndex = index;
        updateLightboxImage();
      });
    });
  }
  
  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('active')) return;
    
    switch (e.key) {
      case 'Escape':
        closeLightbox();
        break;
      case 'ArrowLeft':
        goToPrev();
        break;
      case 'ArrowRight':
        goToNext();
        break;
    }
  });
  
  // Close on backdrop click
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target.classList.contains('lightbox-backdrop')) {
      closeLightbox();
    }
  });
  
  // Touch swipe support for mobile
  let touchStartX = 0;
  let touchEndX = 0;
  
  const lightboxMain = document.querySelector('.lightbox-main');
  if (lightboxMain) {
    lightboxMain.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    
    lightboxMain.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      
      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          goToNext();
        } else {
          goToPrev();
        }
      }
    }, { passive: true });
  }
</script>
